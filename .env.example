# HAK Environment Variables
# Copy this file to .env and fill in the values

# AWS Configuration (optional for local dev)
AWS_REGION=eu-west-1
AWS_ACCOUNT_ID=

# SimpleStore
DYNAMODB_TABLE_NAME=hak-store

# Audio API
BUCKET_NAME=hak-audio
QUEUE_URL=

# Merlin API
SQS_QUEUE_URL=
S3_BUCKET=
ECS_CLUSTER=
ECS_SERVICE=

# Vabamorf API
VMETAJSON_PATH=./vmetajson
DICT_PATH=.
VMETAJSON_TIMEOUT_MS=5000

# Frontend (Vite)
VITE_API_URL=http://localhost:4001

# Logging
LOG_LEVEL=info
