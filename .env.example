# HAK Environment Variables
# Copy this file to .env and fill in the values

# AWS Configuration (optional for local dev)
AWS_REGION=eu-west-1
AWS_ACCOUNT_ID=

# SimpleStore
DYNAMODB_TABLE_NAME=hak-store

# Audio API
BUCKET_NAME=hak-audio
QUEUE_URL=

# Merlin API
SQS_QUEUE_URL=
S3_BUCKET=
ECS_CLUSTER=
ECS_SERVICE=

# Vabamorf API
VMETAJSON_PATH=./vmetajson
DICT_PATH=.
VMETAJSON_TIMEOUT_MS=5000

# Frontend (Vite)
VITE_API_URL=http://localhost:4001
VITE_VABAMORF_URL=http://localhost:8080
VITE_MERLIN_URL=http://localhost:8081
VITE_AUDIO_API_URL=http://localhost:4001

# Cognito Auth (frontend)
VITE_COGNITO_REGION=eu-west-1
VITE_COGNITO_USER_POOL_ID=
VITE_COGNITO_CLIENT_ID=
VITE_COGNITO_DOMAIN=

# Deployment (Serverless Framework / Terraform)
DOMAIN_NAME=example.com
CERTIFICATE_ARN=
HOSTED_ZONE_ID=
COGNITO_USER_POOL_ARN=

# E2E Testing
E2E_SECRET_ID=test/e2e-credentials

# Logging
LOG_LEVEL=info
