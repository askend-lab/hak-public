# HAK Frontend Environment Variables
# Copy to .env.local and fill in values for authentication to work.
# The dev server works WITHOUT these — API calls are proxied to deployed services.

# --- Authentication (TARA / Cognito) ---
# Required only if you need login functionality.
VITE_COGNITO_REGION=eu-west-1
VITE_COGNITO_USER_POOL_ID=
VITE_COGNITO_CLIENT_ID=
VITE_COGNITO_DOMAIN=
VITE_TARA_LOGIN_URL=
VITE_AUTH_API_URL=

# --- Error Tracking (Sentry) ---
# Optional. Errors are silently dropped if not set.
VITE_SENTRY_DSN=

# --- Dev server ---
# VITE_PORT=5181
