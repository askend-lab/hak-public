#!/bin/sh
# DevBox pre-commit hook
set -e
PROJECT_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$PROJECT_ROOT"

DEVBOX_CLI="$PROJECT_ROOT/node_modules/.bin/devbox"
DEVBOX_LOCAL="/home/alex/users/boxer/devbox/packages/hooks/src/cli/index.js"

if [ -x "$DEVBOX_CLI" ]; then
  "$DEVBOX_CLI" run pre-commit
elif [ -f "$DEVBOX_LOCAL" ]; then
  node "$DEVBOX_LOCAL" run pre-commit
else
  echo "⚠ devbox not found — skipping pre-commit hook"
fi
