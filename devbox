#!/usr/bin/env node
// DevBox wrapper - use local devbox in dev, npm package in CI

const { spawnSync } = require('child_process');
const fs = require('fs');
const path = require('path');
const args = process.argv.slice(2);

// Local development path
const localDevbox = '/home/alex/users/boxer/devbox/cli.js';

if (!fs.existsSync(localDevbox)) {
  console.error('Error: Local devbox not found at', localDevbox);
  process.exit(1);
}

const devboxPath = localDevbox;

const result = spawnSync('node', [devboxPath, ...args], { stdio: 'inherit' });
process.exit(result.status || 0);
