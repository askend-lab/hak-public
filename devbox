#!/usr/bin/env node
// DevBox wrapper - finds local or npm devbox

const { execSync } = require('child_process');
const args = process.argv.slice(2).join(' ');

if (process.env.DEVBOX) {
  execSync(`node ${process.env.DEVBOX}/cli.js ${args}`, { stdio: 'inherit' });
} else {
  execSync(`npx @askend-lab/devbox ${args}`, { stdio: 'inherit' });
}
