{
  "name": "hak",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dx": "node devbox dx",
    "dx:cli": "node devbox",
    "test": "node devbox test",
    "test:features": "jest test/features --json --outputFile=jest-results-features.json",
    "test:unit": "jest --testPathIgnorePatterns=test/features --json --outputFile=jest-results-unit.json",
    "test:coverage": "jest --coverage --json --outputFile=jest-results.json",
    "postinstall": "git config core.hooksPath .githooks 2>/dev/null || true",
    "kill-ports": "fuser -k -9 5180/tcp 4000/tcp 3002/tcp 2>/dev/null; sleep 0.2; true",
    "start:frontend": "pnpm --filter @hak/frontend dev",
    "start:backend": "pnpm --filter single-table-lambda dev",
    "start": "pnpm run kill-ports && (pnpm run start:backend & pnpm run start:frontend)"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@askend-lab/devbox": "^0.2.1",
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "@babel/preset-react": "^7.24.0",
    "@babel/preset-typescript": "^7.24.0",
    "@types/estree": "^1.0.8",
    "@types/jest": "^29.5.0",
    "@types/json-schema": "^7.0.15",
    "@types/json5": "^2.2.0",
    "babel-jest": "^29.7.0",
    "eslint": "^9.39.2",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jest": "^29.10.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "jest": "^29.7.0",
    "jest-cucumber": "^3.0.0",
    "ts-jest": "^29.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.50.1"
  },
  "dependencies": {
    "@types/react": "^19.2.7",
    "aws-amplify": "^6.15.9",
    "react": "^19.2.3"
  }
}
