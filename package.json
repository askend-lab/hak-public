{
  "name": "hak",
  "version": "0.1.0",
  "description": "HAK - Estonian Language Learning Platform",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/askend-lab/hak.git"
  },
  "bugs": {
    "url": "https://github.com/askend-lab/hak/issues"
  },
  "homepage": "https://github.com/askend-lab/hak#readme",
  "scripts": {
    "dx": "node devbox dx",
    "dx:cli": "node devbox",
    "test": "node devbox test",
    "test:full": "node devbox test --full",
    "test:all": "pnpm -r --workspace-concurrency=4 run test:full",
    "test:coverage": "jest --coverage --json --outputFile=tmp/jest-results.json",
    "typecheck": "pnpm -r exec tsc --noEmit",
    "lint": "eslint --cache --ext .js,.ts,.tsx . --max-warnings=0 && npx gherkin-lint 'packages/specifications/**/*.feature' && npx stylelint 'packages/frontend/src/styles/**/*.scss' && (cd packages/tts-worker && (test -x .venv/bin/mypy && .venv/bin/mypy worker.py tests/ --ignore-missing-imports || echo 'SKIP: mypy not installed (no .venv)'))",
    "check": "pnpm lint && pnpm typecheck && pnpm test:all",
    "postinstall": "git config core.hooksPath .githooks 2>/dev/null || true",
    "kill-ports": "fuser -k 5181/tcp 2>/dev/null; sleep 0.5; true",
    "start:frontend": "pnpm --filter @hak/frontend dev",
    "start:backend": "pnpm exec tsc --noEmit && pnpm --filter @hak/store dev",
    "start": "pnpm run kill-ports && pnpm run start:frontend"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "aws-sdk",
      "core-js",
      "esbuild",
      "es5-ext",
      "protobufjs",
      "serverless",
      "unrs-resolver"
    ],
    "overrides": {
      "braces": ">=3.0.3",
      "tar": ">=7.5.7",
      "@isaacs/brace-expansion": ">=5.0.1",
      "axios": ">=1.13.5",
      "qs": ">=6.14.2",
      "fast-xml-parser": ">=5.3.6",
      "micromatch": ">=4.0.8",
      "esbuild": ">=0.25.0",
      "lodash": ">=4.17.23",
      "tmp": ">=0.2.4",
      "@smithy/config-resolver": ">=4.4.0",
      "diff": ">=4.0.4"
    },
    "auditConfig": {
      "ignoreCves": [
        "CVE-2026-26996",
        "CVE-2025-69873"
      ]
    }
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.24.0",
    "@babel/preset-react": "^7.24.0",
    "@babel/preset-typescript": "^7.24.0",
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.6.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.0.3",
    "@types/react": "^19.2.7",
    "@typescript-eslint/eslint-plugin": "^8.50.1",
    "@typescript-eslint/parser": "^8.55.0",
    "babel-jest": "^29.7.0",
    "eslint": "^9.39.2",
    "eslint-plugin-eslint-comments": "^3.2.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jest": "^29.10.1",
    "eslint-plugin-jsdoc": "^61.5.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-n": "^17.23.2",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-regexp": "^2.10.0",
    "eslint-plugin-security": "^3.0.1",
    "eslint-plugin-sonarjs": "^3.0.5",
    "eslint-plugin-unicorn": "^62.0.0",
    "fast-check": "^4.5.3",
    "gherkin-lint": "^4.2.4",
    "gitleaks": "^1.0.0",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "knip": "^5.83.1",
    "lint-staged": "^16.1.0",
    "madge": "^8.0.0",
    "nx": "22.5.2",
    "postcss-scss": "^4.0.9",
    "stylelint": "^17.3.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "typescript": "^5.9.3"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,cjs}": "eslint --max-warnings=0"
  }
}
