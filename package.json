{
  "name": "hak",
  "version": "0.1.1",
  "description": "HAK - Estonian Language Learning Platform",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/askend-lab/hak.git"
  },
  "bugs": {
    "url": "https://github.com/askend-lab/hak/issues"
  },
  "homepage": "https://github.com/askend-lab/hak#readme",
  "scripts": {
    "dx": "node devbox dx",
    "dx:cli": "node devbox",
    "test": "node devbox test",
    "test:full": "node devbox test --full",
    "test:coverage": "jest --coverage --json --outputFile=tmp/jest-results.json",
    "lint": "eslint --ext .js,.ts,.tsx . --max-warnings=0 && npx gherkin-lint 'packages/specifications/**/*.feature'",
    "postinstall": "git config core.hooksPath .githooks 2>/dev/null || true",
    "kill-ports": "lsof -ti:5181 | xargs -r kill -9 2>/dev/null; sleep 0.5; true",
    "start:frontend": "pnpm --filter @hak/frontend dev",
    "start:backend": "pnpm exec tsc --noEmit && pnpm --filter simplestore dev",
    "start": "pnpm run kill-ports && pnpm run start:frontend"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "pnpm": {
    "overrides": {
      "braces": ">=3.0.3",
      "tar": ">=7.5.7",
      "@isaacs/brace-expansion": ">=5.0.1",
      "axios": ">=1.13.5",
      "qs": ">=6.14.1",
      "fast-xml-parser": ">=5.3.4",
      "micromatch": ">=4.0.8",
      "esbuild": ">=0.25.0",
      "lodash": ">=4.17.23",
      "tmp": ">=0.2.4",
      "@smithy/config-resolver": ">=4.4.0",
      "diff": ">=4.0.4"
    }
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.24.0",
    "@babel/preset-react": "^7.24.0",
    "@babel/preset-typescript": "^7.24.0",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.57.0",
    "@size-limit/preset-small-lib": "^12.0.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^25.0.3",
    "@types/react": "^19.2.7",
    "@typescript-eslint/eslint-plugin": "^8.50.1",
    "@typescript-eslint/parser": "^8.50.1",
    "babel-jest": "^29.7.0",
    "eslint": "^9.39.2",
    "eslint-plugin-eslint-comments": "^3.2.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jest": "^29.10.1",
    "eslint-plugin-jsdoc": "^61.5.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-n": "^17.23.1",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-regexp": "^2.10.0",
    "eslint-plugin-security": "^3.0.1",
    "eslint-plugin-sonarjs": "^3.0.5",
    "eslint-plugin-unicorn": "^62.0.0",
    "fast-check": "^4.5.3",
    "gherkin-lint": "^4.2.4",
    "gitleaks": "^1.0.0",
    "hadolint": "^0.4.2",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "knip": "^5.83.1",
    "madge": "^8.0.0",
    "ts-jest": "^29.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.50.1"
  }
}
