{
  "name": "hak",
  "version": "0.1.0",
  "description": "HAK - Estonian Language Learning Platform",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/askend-lab/hak-public.git"
  },
  "bugs": {
    "url": "https://github.com/askend-lab/hak-public/issues"
  },
  "homepage": "https://github.com/askend-lab/hak-public#readme",
  "scripts": {
    "test": "pnpm -r --filter !@hak/tts-worker --filter !hak --workspace-concurrency=4 run test:full",
    "test:full": "pnpm -r --filter !@hak/tts-worker --filter !hak --workspace-concurrency=4 run test:full",
    "test:all": "pnpm -r --filter !@hak/tts-worker --filter !hak --workspace-concurrency=4 run test:full",
    "test:coverage": "pnpm -r --filter=@hak/frontend run test:coverage",
    "typecheck": "pnpm --filter @hak/frontend --filter @hak/shared exec tsc --noEmit",
    "lint": "eslint --max-warnings=0 .",
    "check": "pnpm lint && pnpm typecheck && pnpm test:all",
    "start:frontend": "pnpm --filter @hak/frontend dev",
    "start": "pnpm --filter @hak/frontend dev",
    "prepare": "husky",
    "build": "pnpm --filter @hak/frontend build"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "aws-sdk",
      "core-js",
      "esbuild",
      "es5-ext",
      "protobufjs",
      "serverless",
      "unrs-resolver"
    ],
    "overrides": {
      "braces": ">=3.0.3",
      "tar": ">=7.5.7",
      "@isaacs/brace-expansion": ">=5.0.1",
      "axios": ">=1.13.5",
      "qs": ">=6.14.2",
      "fast-xml-parser": ">=5.3.6",
      "micromatch": ">=4.0.8",
      "esbuild": ">=0.25.0",
      "lodash": ">=4.17.23",
      "tmp": ">=0.2.4",
      "@smithy/config-resolver": ">=4.4.0",
      "diff": ">=4.0.4"
    },
    "auditConfig": {
      "ignoreCves": [
        "CVE-2026-26996",
        "CVE-2025-69873"
      ]
    }
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.24.0",
    "@babel/preset-react": "^7.24.0",
    "@babel/preset-typescript": "^7.24.0",
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.6.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.0.3",
    "@types/react": "^19.2.7",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "babel-jest": "^29.7.0",
    "eslint": "^9.39.2",
    "eslint-plugin-eslint-comments": "^3.2.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jest": "^29.15.2",
    "eslint-plugin-jsdoc": "^61.5.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-n": "^17.23.2",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-regexp": "^2.10.0",
    "eslint-plugin-security": "^3.0.1",
    "eslint-plugin-sonarjs": "^3.0.5",
    "eslint-plugin-unicorn": "^62.0.0",
    "fast-check": "^4.7.0",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "lint-staged": "^16.1.0",
    "nx": "22.6.5",
    "postcss-scss": "^4.0.9",
    "stylelint": "^17.8.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "typescript": "^5.9.3"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,cjs}": "eslint --max-warnings=0"
  }
}
