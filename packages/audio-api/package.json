{
  "name": "audio-api",
  "version": "1.0.0",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "test": "jest --changedSince=HEAD --json --outputFile=jest-results.json",
    "test:full": "NODE_OPTIONS=--experimental-vm-modules jest --testPathIgnorePatterns=test/features --json --outputFile=jest-results.json",
    "test:e2e": "NODE_OPTIONS=--experimental-vm-modules jest --testPathPattern=test/features --json --outputFile=jest-results.json",
    "test:coverage": "jest --coverage --json --outputFile=jest-results.json",
    "test:watch": "jest --watch"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.6",
    "jest": "^29.7.0",
    "serverless-esbuild": "^1.57.0",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.985.0",
    "@aws-sdk/client-sqs": "^3.985.0",
    "@hak/shared": "workspace:*"
  }
}
