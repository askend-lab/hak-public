# Frontend environment variables
# Copy this file to .env.local and fill in the values

# Sentry error tracking (optional — only active when cookie consent accepted)
VITE_SENTRY_DSN=

# Local dev server port (optional, default: 5181)
VITE_PORT=5181

# TARA authentication
VITE_TARA_LOGIN_URL=

# Auth API base URL
VITE_AUTH_API_URL=

# AWS Cognito configuration
VITE_COGNITO_REGION=
VITE_COGNITO_USER_POOL_ID=
VITE_COGNITO_CLIENT_ID=
VITE_COGNITO_DOMAIN=
