{
  "name": "@hak/frontend",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test:full": "vitest run",
    "test": "vitest run --changed",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage --coverage.reporter=json-summary --coverage.reporter=text --coverage.reportOnFailure",
    "test:cucumber": "NODE_OPTIONS='--import tsx' cucumber-js --config cucumber.cjs",
    "cucumber:coverage": "NODE_OPTIONS='--import tsx' c8 --reporter=json-summary --reports-dir=coverage-cucumber --include='src/**/*.ts' --include='src/**/*.tsx' --exclude='src/**/*.test.*' cucumber-js --config cucumber.cjs --profile coverage",
    "sync-features": "node scripts/sync-features.js",
    "prebuild": "node scripts/sync-features.js",
    "lint": "eslint . --ext .ts,.tsx --max-warnings=0",
    "lint:fix": "eslint . --ext .ts,.tsx --fix --max-warnings=0",
    "validate:design": "node scripts/validate-design.js",
    "validate:design:json": "node scripts/validate-design.js --json",
    "validate:design:suggestions": "node scripts/validate-design.js --fix-suggestions",
    "test:a11y": "playwright test e2e/accessibility.spec.ts",
    "test:a11y:report": "playwright test e2e/accessibility.spec.ts --reporter=html"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hak/shared": "workspace:*",
    "@hak/specifications": "workspace:*",
    "@tanstack/react-query": "^5.60.0",
    "i18next-http-backend": "^3.0.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.10.1",
    "zod": "^3.23.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@aws-sdk/client-secrets-manager": "^3.964.0",
    "@axe-core/playwright": "^4.11.0",
    "@axe-core/react": "^4.11.0",
    "@cucumber/cucumber": "^12.4.0",
    "@eslint/js": "^9.15.0",
    "@playwright/test": "^1.57.0",
    "@sentry/react": "^10.33.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/chai": "^5.2.3",
    "@types/jest": "^29.5.0",
    "@types/jest-axe": "^3.5.9",
    "@types/jsdom": "^27.0.0",
    "@types/node": "^25.0.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.15.0",
    "@typescript-eslint/parser": "^8.15.0",
    "@vitejs/plugin-react": "^5.1.2",
    "@vitest/coverage-v8": "^4.0.16",
    "axe-core": "^4.11.1",
    "c8": "^10.1.3",
    "chai": "^6.2.2",
    "eslint": "^9.15.0",
    "eslint-import-resolver-typescript": "^3.6.3",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "happy-dom": "^20.0.11",
    "i18next": "^25.7.3",
    "jest": "^29.7.0",
    "jest-axe": "^10.0.0",
    "jest-cucumber": "^3.0.0",
    "jest-environment-jsdom": "^29.7.0",
    "jsdom": "^27.3.0",
    "nyc": "^17.1.0",
    "playwright": "^1.57.0",
    "react-i18next": "^16.5.0",
    "sass": "^1.97.1",
    "simplestore": "workspace:*",
    "ts-jest": "^29.2.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.15.0",
    "vite": "^7.2.7",
    "vitest": "^4.0.16"
  }
}
