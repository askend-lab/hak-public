{
  "name": "@hak/store",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc && serverless offline --httpPort 4000 --host 0.0.0.0",
    "test": "vitest run --changed HEAD --reporter=json --outputFile=test-results.json",
    "test:full": "vitest run --reporter=json --outputFile=test-results.json",
    "test:coverage": "vitest run --coverage --reporter=json --outputFile=test-results.json"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.160",
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^4.0.16",
    "esbuild": "^0.27.1",
    "serverless": "^4.32.0",
    "serverless-domain-manager": "^9.1.0",
    "serverless-esbuild": "^1.57.0",
    "serverless-offline": "^14.4.0",
    "typescript": "^5.0.0",
    "vitest": "^4.0.16"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.990.0",
    "@aws-sdk/lib-dynamodb": "^3.990.0",
    "@hak/shared": "workspace:*",
    "zod": "^3.25.76"
  }
}
