{
  "name": "@hak/tts-api",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "test:full": "jest --json --outputFile=jest-results.json",
    "generate:openapi": "ts-node src/openapi.ts > openapi.yaml",
    "deploy": "serverless deploy",
    "deploy:dev": "serverless deploy --stage dev",
    "deploy:prod": "serverless deploy --stage prod"
  },
  "devDependencies": {
    "@asteasolutions/zod-to-openapi": "^7.3.4",
    "@types/jest": "^30.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.10.6",
    "jest": "^30.3.0",
    "js-yaml": "^4.1.0",
    "serverless": "^4.32.0",
    "serverless-domain-manager": "^9.1.0",
    "serverless-esbuild": "^1.57.0",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "@aws-sdk/client-ecs": "^3.1019.0",
    "@aws-sdk/client-s3": "^3.1019.0",
    "@aws-sdk/client-sqs": "^3.1019.0",
    "@hak/shared": "workspace:*",
    "zod": "^3.25.76"
  }
}
